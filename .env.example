# Database
POSTGRES_DB=cryptopal
POSTGRES_USER=cryptopal
POSTGRES_PASSWORD=cryptopal_password
DATABASE_URL=jdbc:postgresql://localhost:5432/cryptopal

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Sessions
SESSION_TTL_MINUTES=120

# Market data
MARKET_PROVIDER=binance
BINANCE_BASE_URL=https://api.binance.com
SUPPORTED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT

# Gemini
# Get a free key at https://aistudio.google.com/apikey
# Backend only. This key must never be sent to the browser.
# Without it the app still runs, and /api/ai/ask answers AI_UNAVAILABLE.
GEMINI_API_KEY=replace_me
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# Pinned rather than using the gemini-flash-latest alias, so the model cannot change
# under the project. Chosen by measuring against the real API: flash-lite answered a
# realistic prompt in about 1s with no thinking tokens, gemini-flash-latest took about
# 7s, and gemini-3.5-flash took about 17s and was returning 503 "high demand".
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_SECONDS=20

# How many questions the assistant will answer, per user and in total, in a rolling 24
# hours. Gemini is the one dependency whose capacity I do not own, and the key runs on a
# free tier, so running out costs the feature rather than money: one visitor emptying the
# day's quota would leave the assistant dead for everyone, including during a demo.
# The per-user limit is fairness. The global one is the real protection, because
# registration is open and ten accounts would otherwise mean ten times the allowance.
AI_DAILY_QUESTION_LIMIT=20
AI_DAILY_GLOBAL_LIMIT=300

# Frontend
VITE_API_BASE_URL=http://localhost:8080
